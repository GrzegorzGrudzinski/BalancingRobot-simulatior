  <joint name="frame_to_wheel_1" type="continuous">
    <origin xyz="0.0898 0.0374378 -0.0449916" rpy="1.5708 0 1.5708"/>
    <parent link="frame"/>
    <child link="wheel"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.0" velocity="50"/> 
    <dynamics damping="0.01" friction="0.02"/>
