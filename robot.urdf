  <link name="wheel">
    <inertial>
      <origin xyz="0 0 0.00154919" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="2.08867e-05" ixy="0" ixz="0" iyy="2.08867e-05" iyz="0" izz="4.17237e-05"/>
